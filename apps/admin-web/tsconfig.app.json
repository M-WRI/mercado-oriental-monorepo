{
  "extends": "../../packages/config/typescript/web-app.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@/_shared/queryProvider": ["../../packages/shared-ui/src/api/index.ts"],
      "@/_shared/hooks": ["../../packages/shared-ui/src/index.ts"],
      "@/_shared/components/auth": ["./src/app/components/auth/index.ts"],
      "@/_shared/layout": ["./src/app/layout/index.ts"],
      "@/_shared/context/*": ["./src/app/context/*"],
      "@/_shared/*": ["./src/app/*"],
      "@mercado/shared-ui": ["../../packages/shared-ui/src/index.ts"],
      "@mercado/shared-ui/*": ["../../packages/shared-ui/src/*"]
    }
  },
  "include": ["src", "../../packages/shared-ui/src"]
}
